      }
    },
    "production": {
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://crestoneapp-production.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
